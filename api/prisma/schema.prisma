  verifiedPurchase Boolean         @default(false)
  product          Product?        @relation(fields: [productId], references: [id])
  purchaseOrder    PurchaseOrder?  @relation("PurchaseOrderToSupplierReviews", fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  supplier         Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([supplierId, productId, userId], name: "SupplierReview_user_product_unique")
  @@index([supplierId, createdAt])
  @@index([purchaseOrderId])
  @@index([productId])
  @@index([variantId])
}

model JobApplication {
  id          String               @id @default(cuid())
  createdAt   DateTime             @default(now())
  name        String
  email       String
  roleId      String?
  roleTitle   String?
  linkedinUrl String?
  message     String
  ip          String?
  userAgent   String?
  cvFilename  String?
  cvMimeType  String?
  cvSize      Int?
  notes       String?
  status      JobApplicationStatus @default(NEW)

  @@index([email, createdAt])
  @@index([roleId, createdAt])
}

model Employee {
  id             String                @id @default(cuid())
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  firstName      String
  lastName       String
  emailWork      String?
  emailPersonal  String?
  phone          String?
  jobTitle       String?
  department     String?
  status         EmployeeStatus        @default(ACTIVE)
  startDate      DateTime?
  baseSalaryNGN  Int?
  payFrequency   EmployeePayFrequency?
  bankName       String?
  bankCode       String?
  accountNumber  String?
  accountName    String?
  isPayrollReady Boolean               @default(false)
  hasPassportDoc Boolean               @default(false)
  hasNinSlipDoc  Boolean               @default(false)
  hasTaxDoc      Boolean               @default(false)
  documents      EmployeeDocument[]

  @@index([status, department])
  @@index([emailWork])
  @@index([emailPersonal])
}

model EmployeeDocument {
  id               String               @id @default(cuid())
  createdAt        DateTime             @default(now())
  employeeId       String
  kind             EmployeeDocumentKind
  storageKey       String
  originalFilename String
  mimeType         String?
  size             Int?
  uploadedByUserId String?
  employee         Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, kind])
}

model CareersJobRole {
  id                   String                 @id @default(cuid())
  slug                 String                 @unique
  title                String
  department           String?
  location             String?
  locationType         CareersLocationType?
  employmentType       CareersEmploymentType?
  minSalary            Int?
  maxSalary            Int?
  currency             String?                @default("NGN")
  isPublished          Boolean                @default(false)
  isDeleted            Boolean                @default(false)
  sortOrder            Int                    @default(0)
  applicationEmail     String?
  applicationUrl       String?
  introHtml            String?
  responsibilitiesJson Json?
  requirementsJson     Json?
  benefitsJson         Json?
  closingDate          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

model CareersSettings {
  id                    Int                  @id @default(1)
  isCareersEnabled      Boolean              @default(true)
  allowOpenApplications Boolean              @default(false)
  careersEmail          String?
  careersInboxLabel     String?
  defaultLocation       String?
  defaultLocationType   CareersLocationType?
  careersIntroHtml      String?
  careersFooterHtml     String?
  seoTitle              String?
  seoDescription        String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  source         String?
  meta           Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
}

model ProductAttribute {
  id          String    @id @default(cuid())
  productId   String
  attributeId String
  createdAt   DateTime  @default(now())
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@index([productId])
  @@index([attributeId])
}

