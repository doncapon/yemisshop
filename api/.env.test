# api/.env.test
# Environment variables for test runs.
# Copy this file to .env.test.local and fill in real values if you want
# integration tests to hit a real database.

NODE_ENV=test

# ── Test database ─────────────────────────────────────────────────────────────
# Uncomment and set this to a dedicated test PostgreSQL database.
# NEVER point at your production or main dev database.
# TEST_DATABASE_URL="postgresql://yemi:yemipass@localhost:5432/yemisshop_test?schema=public"

# Fallback: uses DATABASE_URL from .env if TEST_DATABASE_URL is not set.
# Unit tests mock Prisma, so no DB is needed for those.

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=test-jwt-secret-do-not-use-in-production
ACCESS_JWT_SECRET=test-jwt-secret-do-not-use-in-production

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave empty to prevent real emails being sent during tests
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
